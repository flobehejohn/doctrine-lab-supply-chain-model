{
  "name": "doctrine-lab-supply-chain-model",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "description": "Doctrine Supply Chain Mode Lab - clean-room DevSecOps supply chain evidence lab.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "dev": "pnpm --filter @supply-chain-mode-lab/web dev",
    "supplychain:certify": "pnpm typecheck && pnpm test && pnpm supplychain:validate -- --input labs/supply-chain/examples/ecommerce/evidence-pack.json && pnpm supplychain:graph:certify && pnpm web:build && pnpm operator:certify && pnpm security:certify && pnpm template:certify && pnpm report:readable:certify && pnpm artifact:certify",
    "supplychain:validate": "tsx scripts/supplychain/validate-evidence-pack.ts",
    "supplychain:graph:certify": "tsx scripts/supplychain/certify-lab.ts --input labs/supply-chain/examples/ecommerce/evidence-pack.json",
    "web:build": "pnpm --filter @supply-chain-mode-lab/web build",
    "ux:audit": "tsx scripts/ui/capture-demo.ts",
    "demo:capture": "pnpm ux:audit",
    "report:jtable:findings": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/reporting/render-jtable.ps1 -View reporting/jtable/views/findings-all.yml",
    "report:jtable:critical": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/reporting/render-jtable.ps1 -View reporting/jtable/views/findings-critical.yml",
    "report:jtable:compliance": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/reporting/render-jtable.ps1 -View reporting/jtable/views/compliance-summary.yml",
    "report:jtable:remediations": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/reporting/render-jtable.ps1 -View reporting/jtable/views/remediation-pr-table.yml",
    "report:jtable:all": "pnpm run report:jtable:findings && pnpm run report:jtable:critical && pnpm run report:jtable:compliance && pnpm run report:jtable:remediations",
    "operator:certify": "tsx scripts/operator/certify-cookbook.ts",
    "security:certify": "tsx scripts/security/certify-command-runner.ts",
    "template:generate": "tsx scripts/reporting/generate-template-artifacts.ts",
    "template:certify": "pnpm template:generate",
    "report:markdown:audit": "tsx scripts/reporting/render-markdown-audit.ts",
    "report:mermaid:graph": "tsx scripts/reporting/render-mermaid-graph.ts",
    "report:marp:executive": "tsx scripts/reporting/render-marp-executive.ts",
    "report:readable:generate": "pnpm report:markdown:audit && pnpm report:mermaid:graph && pnpm report:marp:executive",
    "report:readable:certify": "pnpm report:readable:generate && tsx scripts/reporting/certify-readable-reports.ts",
    "artifact:certify": "pnpm report:readable:certify && tsx scripts/artifacts/certify-artifact-pipeline.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
