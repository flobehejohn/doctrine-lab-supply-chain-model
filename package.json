{
  "name": "doctrine-lab-supply-chain-model",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "description": "Doctrine Supply Chain Mode Lab - clean-room DevSecOps supply chain evidence lab.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "dev": "pnpm --filter @supply-chain-mode-lab/web dev",
    "supplychain:certify": "pnpm typecheck && pnpm test && pnpm supplychain:validate -- --input labs/supply-chain/examples/ecommerce/evidence-pack.json && pnpm supplychain:graph:certify && pnpm web:build",
    "supplychain:validate": "tsx scripts/supplychain/validate-evidence-pack.ts",
    "supplychain:graph:certify": "tsx scripts/supplychain/certify-lab.ts --input labs/supply-chain/examples/ecommerce/evidence-pack.json",
    "web:build": "pnpm --filter @supply-chain-mode-lab/web build",
    "ux:audit": "tsx scripts/ui/capture-demo.ts",
    "demo:capture": "pnpm ux:audit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
