{
  "schemaVersion": "dreps-blast-radius.input.v1",
  "scenario": "repo_compromise",
  "startNode": "repo-auth-service",
  "maxDepth": 7,
  "edgeWeights": {
    "triggers": 0.9,
    "builds": 0.85,
    "publishes": 0.8,
    "deploys": 0.9,
    "runs": 0.75,
    "connects_to": 0.95,
    "reads_from": 0.8,
    "writes_to": 0.9,
